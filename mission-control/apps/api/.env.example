// ZERO-BUDGET ENVIRONMENT VARIABLES
// Replace with your actual free API keys

// Google Gemini AI (Free tier: 15 requests/minute)
GEMINI_API_KEY=your_gemini_api_key_here

// Supabase (Free tier: 500MB database, 50MB file storage)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key_here

// Hugging Face (Free for basic models)
HUGGINGFACE_API_KEY=your_huggingface_token_here

// Local server configuration
PORT=3001
NODE_ENV=development

// File upload limits
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

// OCR and ML Models
USE_ON_DEVICE_OCR=true
FALLBACK_OCR_ENGINE=tesseract

// Rate limiting (free tier friendly)
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

// Cache settings
ENABLE_EMBEDDING_CACHE=true
CACHE_TTL_HOURS=24

// Feature flags for MVP
ENABLE_CONTRACT_ANALYSIS=false
ENABLE_VOICE_COMMANDS=true
ENABLE_SEMANTIC_SEARCH=true
ENABLE_VAULT_ENCRYPTION=true

// Stripe billing (metered usage)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_METER_EVENT_NAME=api_calls