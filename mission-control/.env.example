# ============================================================
# OraClaw API — Environment Variables
# ============================================================
# Copy to .env and fill in values:
#   cp .env.example .env
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Supabase or self-hosted)
# Leave empty to use in-memory fallback (dev only)
DATABASE_URL=

# ── Supabase (optional — for file storage and advanced features)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Authentication ───────────────────────────────────────────
# Unkey API key management (https://unkey.dev)
UNKEY_ROOT_KEY=
UNKEY_API_ID=

# JWT secrets (for internal auth routes, not public API)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# ── Stripe Billing ───────────────────────────────────────────
# Stripe API keys (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Billing Meter event names
STRIPE_METER_EVENT_NAME=api_calls
STRIPE_BATCH_METER_EVENT_NAME=api_calls_batch

# Stripe Price IDs for subscription tiers
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Customer portal return URL
PORTAL_RETURN_URL=https://oraclaw.dev

# ── x402 Machine Payments (USDC on Base) ─────────────────────
# Receiving wallet address for USDC payments
RECEIVING_WALLET_ADDRESS=0x...

# Price per API call (USDC)
X402_PRICE_PER_CALL=$0.001

# Chain network identifier
# Base mainnet: eip155:8453
# Base Sepolia testnet: eip155:84532
X402_NETWORK=eip155:84532

# x402 facilitator URL
X402_FACILITATOR_URL=https://x402.org/facilitator

# ── AI Services (optional) ──────────────────────────────────
# Google Gemini API key (for NLP query endpoint)
GEMINI_API_KEY=

# ── Google OAuth (optional — for Gmail integration) ─────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/oauth/gmail/callback
