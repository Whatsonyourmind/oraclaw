{
  "dashboard": {
    "id": null,
    "uid": "oracle-overview",
    "title": "ORACLE v2.0 Overview",
    "description": "ORACLE v2.0 Production Monitoring Dashboard",
    "tags": ["oracle", "production", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "row",
        "title": "Overview",
        "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Predictions",
        "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(oracle_predictions_total)",
            "legendFormat": "Total"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "type": "gauge",
        "title": "Prediction Success Rate",
        "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(oracle_predictions_total{status=\"success\"}) / sum(oracle_predictions_total) * 100",
            "legendFormat": "Success Rate"
          }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 80 },
                { "color": "green", "value": 95 }
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Active Users",
        "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "oracle_active_users{type=\"total\"}",
            "legendFormat": "Active"
          }
        ],
        "options": {
          "colorMode": "value"
        }
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Request Rate",
        "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "rate(oracle_http_requests_total[5m])",
            "legendFormat": "req/s"
          }
        ],
        "options": {
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps"
          }
        }
      },
      {
        "id": 10,
        "type": "row",
        "title": "Performance",
        "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }
      },
      {
        "id": 11,
        "type": "timeseries",
        "title": "API Latency (p50, p95, p99)",
        "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(oracle_api_latency_seconds_bucket[5m]))",
            "legendFormat": "p99"
          },
          {
            "expr": "histogram_quantile(0.95, rate(oracle_api_latency_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.50, rate(oracle_api_latency_seconds_bucket[5m]))",
            "legendFormat": "p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 12,
        "type": "timeseries",
        "title": "Simulation Duration",
        "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(oracle_simulation_duration_seconds_bucket[5m]))",
            "legendFormat": "{{type}} p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 20,
        "type": "row",
        "title": "ORACLE Metrics",
        "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
      },
      {
        "id": 21,
        "type": "timeseries",
        "title": "Signals by Type",
        "gridPos": { "x": 0, "y": 15, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(oracle_signals_total[5m])",
            "legendFormat": "{{type}}"
          }
        ]
      },
      {
        "id": 22,
        "type": "timeseries",
        "title": "Decisions by Phase",
        "gridPos": { "x": 8, "y": 15, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(oracle_decisions_total[5m])",
            "legendFormat": "{{phase}}"
          }
        ]
      },
      {
        "id": 23,
        "type": "timeseries",
        "title": "Error Rate",
        "gridPos": { "x": 16, "y": 15, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "rate(oracle_errors_total[5m])",
            "legendFormat": "{{type}} - {{source}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineStyle": {
                "fill": "solid"
              }
            }
          }
        }
      },
      {
        "id": 30,
        "type": "row",
        "title": "Infrastructure",
        "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }
      },
      {
        "id": 31,
        "type": "timeseries",
        "title": "Memory Usage",
        "gridPos": { "x": 0, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "oracle_process_memory_bytes",
            "legendFormat": "{{type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 32,
        "type": "timeseries",
        "title": "Queue Sizes",
        "gridPos": { "x": 8, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "oracle_queue_size",
            "legendFormat": "{{queue_name}} - {{status}}"
          }
        ]
      },
      {
        "id": 33,
        "type": "gauge",
        "title": "Cache Hit Ratio",
        "gridPos": { "x": 16, "y": 22, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "oracle_cache_hit_ratio",
            "legendFormat": "{{cache_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.9 }
              ]
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "prometheus",
          "enable": true,
          "expr": "changes(oracle_process_start_time_seconds[5m])",
          "titleFormat": "Deployment",
          "tagKeys": "service"
        }
      ]
    }
  },
  "overwrite": true,
  "inputs": [],
  "folderId": 0
}
